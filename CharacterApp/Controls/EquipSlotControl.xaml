<UserControl x:Class="CharacterApp.Controls.EquipSlotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CharacterApp.Models"
             Width="186" Height="252"
             MinWidth="120" MinHeight="150"
             AllowDrop="True">
    <Border x:Name="MainBorder"
            Style="{StaticResource CardStyle}"
            Padding="8"
            Margin="6"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock x:Name="TitleText" Text="Слот" FontWeight="SemiBold" HorizontalAlignment="Center"/>

            <!-- Изображение -->
            <Border Grid.Row="1" CornerRadius="8" Margin="0,8,0,8"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" MinHeight="88">
                <Grid>
                    <Image x:Name="ImgItem" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="110" MaxHeight="110"/>
                    <Image x:Name="ImgPlaceholder" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Visibility="Collapsed"/>
                    <!-- Полупрозрачный тёмный оверлей при блокировке (если нужно) -->
                    <Rectangle x:Name="LockedOverlay" Fill="{DynamicResource SlotLockedOverlay}" RadiusX="8" RadiusY="8" Visibility="Collapsed" Opacity="0.6"/>
                </Grid>
            </Border>

            <!-- Имя и кнопки -->
            <StackPanel Grid.Row="2" Orientation="Vertical">
                <TextBlock x:Name="TxtName" Text="—" TextAlignment="Center" TextWrapping="Wrap" Margin="2" MaxHeight="36"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button x:Name="BtnChoose" Click="BtnChoose_Click" ToolTip="Выбрать изображение" Width="34" Height="28" Margin="2">+</Button>
                    <Button x:Name="BtnView" Click="BtnView_Click" ToolTip="Просмотреть" Width="34" Height="28" Margin="2">👁</Button>
                    <Button x:Name="BtnEdit" Click="BtnEdit_Click" ToolTip="Редактировать" Width="34" Height="28" Margin="2">✎</Button>
                    <Button x:Name="BtnClear" Click="BtnClear_Click" ToolTip="Удалить" Width="34" Height="28" Margin="2">×</Button>
                </StackPanel>
            </StackPanel>

            <!-- Кнопка блокировки (вверху справа) -->
            <Button x:Name="LockBtn" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,4,4,0" Click="LockBtn_Click" ToolTip="Заблокировать/Разблокировать слот"
                    Background="Transparent" BorderThickness="0">
                <Image x:Name="LockBtnImage" Stretch="Uniform" Width="20" Height="20"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
