<Window x:Class="CharacterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CharacterApp.Controls"
        xmlns:pages="clr-namespace:CharacterApp.Pages"
        xmlns:chrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:CharacterApp"
        Title="Espires Games" Height="800" Width="1000"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}" Icon="/Images/EspiresGames.ico">

    <!-- Локальные ресурсы -->
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#70FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <chrome:WindowChrome.WindowChrome>
        <chrome:WindowChrome
      CaptionHeight="0"
      ResizeBorderThickness="5"
      GlassFrameThickness="0"
      UseAeroCaptionButtons="False"
      NonClientFrameEdges="Left,Right,Bottom"/>
    </chrome:WindowChrome.WindowChrome>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AccentBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Grid.Column="0"
                            Margin="10,0,5,0">
                    <Image Source="/Images/EspiresGames.ico"
                           Width="20" Height="20"
                           VerticalAlignment="Center"/>
                    <TextBlock Text="Espires Games"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"/>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Grid.Column="2" Panel.ZIndex="999" Margin="0,0,10,0">
                    <Button
    chrome:WindowChrome.IsHitTestVisibleInChrome="False"
    Click="Minimize_Click"
    Style="{DynamicResource TitleBarButtonStyle}"
    ToolTip="Свернуть" Margin="0,0,10,0">
                        <Path Data="M0,5 L10,5"
          Stroke="White"
          StrokeThickness="2"/>
                    </Button>
                    <Button
    chrome:WindowChrome.IsHitTestVisibleInChrome="False"
    Click="Close_Click"
    Style="{DynamicResource TitleBarButtonStyle}"
    ToolTip="Закрыть">
                        <Path Data="M0,0 L10,10 M0,10 L10,0"
          Stroke="White"
          StrokeThickness="2"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="323*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR: замените старый DockPanel на этот -->
            <!-- SIDEBAR -->
            <DockPanel Grid.Column="0" Background="#AA333333" x:Name="Sidebar" Width="250">
                <!-- Верх: бургер + поиск -->
                <StackPanel DockPanel.Dock="Top" Margin="8">
                    <Button x:Name="BtnToggleMenu"
                Width="38" Height="38"
                HorizontalAlignment="Left"
                Click="BtnToggleMenu_Click"
                ToolTip="Открыть/закрыть меню"
                Margin="5,0,0,8">
                        <Grid Width="20" Height="16">
                            <Rectangle Height="2" Fill="{DynamicResource TextBrush}" VerticalAlignment="Top" RadiusX="1" RadiusY="1"/>
                            <Rectangle Height="2" Fill="{DynamicResource TextBrush}" VerticalAlignment="Center" RadiusX="1" RadiusY="1"/>
                            <Rectangle Height="2" Fill="{DynamicResource TextBrush}" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1"/>
                        </Grid>
                    </Button>

                    <TextBox x:Name="TbMenuSearch"
                 Width="230"
                 Height="28"
                 Margin="0,0,0,8"
                 VerticalAlignment="Center"
                 TextChanged="TbMenuSearch_TextChanged"
                 Visibility="Visible" />
                </StackPanel>

                <!-- Главное меню -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Height="Auto">
                    <StackPanel x:Name="MenuStack" Margin="10,0,10,0" Opacity="1">
                        <TextBlock Text="Меню" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="White" Width="230"/>
                        <Button Content="Главная страница" Click="MainPage_Click" Margin="0,4" Width="230"/>
                        <Button Content="Предыстория" Click="Details_Click" Margin="0,4" Width="230"/>
                        <Button Content="Equipment" Click="Equipment_Click" Margin="0,4" Width="230"/>
                        <Button Content="Active Skills" Click="ActiveSkills_Click" Margin="0,4" Width="230"/>
                        <Button Content="Настройки" Click="Settings_Click" Margin="0,4" Width="230"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Нижний блок с кнопками сохранения -->
                <StackPanel DockPanel.Dock="Bottom" x:Name="BottomButtonsPanel" Background="#FF444444" Height="165" VerticalAlignment="Bottom" Opacity="1">
                    <Button Content="Быстрое сохранение" Click="QuickSave_Click" Margin="0,6,0,4" Width="230"/>
                    <Button Content="Сохранить как" Click="SaveAs_Click" Margin="0,4" Width="230"/>
                    <Button Content="Загрузить" Click="LoadJSON_Click" Margin="0,4" Width="230"/>
                    <Button Content="Проверить обновления" Click="CheckUpdates_Click" Margin="0,4" Width="230"/>
                </StackPanel>
            </DockPanel>



            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="10,10,0,10"/>
            

            <StackPanel x:Name="NotificationHost"
            Grid.Column="1"
            IsHitTestVisible="False"
            VerticalAlignment="Top"
            HorizontalAlignment="Right"
            Width="305"
            Margin="0,10,0,0" Grid.ColumnSpan="2" />
        </Grid>
    </Grid>
</Window>
