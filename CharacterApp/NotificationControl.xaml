<UserControl x:Class="CharacterApp.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Height="Auto" Opacity="0" Margin="0,0,0,10" HorizontalAlignment="Right">
    <Border x:Name="Root"
            Background="#DD333333"
            CornerRadius="5,0,0,5"
            Padding="10"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">
        <DockPanel>
            <!-- Иконка в зависимости от типа -->
            <TextBlock x:Name="IconBlock"
                       DockPanel.Dock="Left"
                       FontSize="18"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="MessageBlock"
                       TextWrapping="Wrap"
                       Foreground="White"/>
        </DockPanel>
    </Border>
</UserControl>
