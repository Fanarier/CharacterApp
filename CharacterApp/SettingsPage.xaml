<Page x:Class="CharacterApp.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки">
    <ScrollViewer>
        <ScrollViewer.Background>
            <ImageBrush ImageSource="/Images/Background_1.png"
                Stretch="None"
                AlignmentX="Left"
                AlignmentY="Top"
                Viewport="0,0,1024,1024"
                ViewportUnits="Absolute"
                TileMode="None" Opacity="0.06" ViewboxUnits="RelativeToBoundingBox"/>
        </ScrollViewer.Background>
        <StackPanel Margin="20" Orientation="Vertical">
            <TextBlock Text="Настройки" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <GroupBox Header="Выбор темы" Margin="5" Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Светлая тема:" VerticalAlignment="Center" Margin="5"/>
                        <Border Width="100" Height="50" Background="White" BorderThickness="1" BorderBrush="Gray" Margin="5">
                            <Border BorderThickness="1" Margin="49,0,0,0" Background="#FF6A9FB5"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Тёмная тема:" VerticalAlignment="Center" Margin="5"/>
                        <Border Width="100" Height="50" Background="#FF2D2D30" BorderThickness="1" BorderBrush="Gray" Margin="5">
                            <Border BorderBrush="#00000000" BorderThickness="1" Margin="49,0,0,0" Background="#FFC07CCA"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" Width="244">
                        <RadioButton x:Name="RbLight" Content="Светлая" Margin="5" VerticalAlignment="Center"/>
                        <RadioButton x:Name="RbDark" Content="Тёмная" Margin="5" VerticalAlignment="Center"/>
                        <Button Content="Подтвердить" Click="ConfirmTheme_Click" Margin="5" Padding="10" Width="91" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource LanguageBtn}" Margin="5" Padding="10">
                <StackPanel HorizontalAlignment="Center">
                    <ComboBox x:Name="LanguageComboBox" Width="200" SelectedValuePath="Tag">
                        <ComboBoxItem Tag="ru" Content="Русский"/>
                        <ComboBoxItem Tag="en" Content="English"/>
                        <ComboBoxItem Tag="jp" Content="日本語"/>
                    </ComboBox>
                    <Button Content="{DynamicResource SettingsBtn}" Click="ApplyLanguage_Click" Margin="5" Padding="10"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Автосохранение" Margin="5" Padding="10">
                <StackPanel>
                    <CheckBox x:Name="CbEnableAutoSave" Content="Включить автосохранение" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Интервал (мин):" VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="TbAutoSaveInterval" Width="60" Height="30"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Папка сохранений:" VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="TbAutoSaveFolder" Width="200" IsReadOnly="True" Height="30"/>
                        <Button Content="..." Click="BrowseFolder_Click" Margin="5,0,0,0" Width="30" Height="30"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Шаблон имени файла:" VerticalAlignment="Center" Width="120"/>
                        <TextBox x:Name="TbAutoSavePattern" Width="200" Height="30"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,10,0,0">
            <Button Content="Сохранить" Click="SaveSettings_Click" Margin="20" Width="100" HorizontalAlignment="Center"/>
            <Button Content="Вернуться" Click="Back_Click" Margin="20" Width="100" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>